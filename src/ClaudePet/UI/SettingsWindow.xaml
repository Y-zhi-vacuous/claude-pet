<Window x:Class="ClaudePet.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude 小狗设置"
        Width="360" Height="380"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 小狗名字 -->
        <TextBlock Grid.Row="0" Text="小狗名字" FontSize="13" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,4" />
        <TextBox x:Name="PetNameBox" Grid.Row="1" FontSize="13"
                 Padding="6,4" Margin="0,0,0,12" BorderBrush="#CCC" />

        <!-- 唤醒词 -->
        <TextBlock Grid.Row="2" Text="唤醒词" FontSize="13" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,4" />
        <TextBox x:Name="WakeWordBox" Grid.Row="3" FontSize="13"
                 Padding="6,4" Margin="0,0,0,12" BorderBrush="#CCC" />

        <!-- 空闲睡眠时间 -->
        <TextBlock Grid.Row="4" Text="空闲睡眠时间（分钟）" FontSize="13" FontWeight="SemiBold"
                   Foreground="#333" Margin="0,0,0,4" />
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider x:Name="SleepSlider" Minimum="1" Maximum="30" Value="5"
                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" />
            <TextBlock x:Name="SleepLabel" Grid.Column="1" Width="40" Text="5分"
                       TextAlignment="Right" FontSize="13" VerticalAlignment="Center"
                       Foreground="#555" />
        </Grid>

        <!-- 语音开关 -->
        <CheckBox x:Name="VoiceCheckBox" Grid.Row="6"
                  Content="开启语音引擎（说唤醒词来控制小狗）"
                  FontSize="13" Foreground="#333" Margin="0,0,0,16" />

        <!-- 按钮 -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="70" Height="30"
                    Background="#E0E0E0" BorderThickness="0" FontSize="13"
                    Click="CancelButton_Click" Margin="0,0,8,0" />
            <Button Content="保存" Width="70" Height="30"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" FontSize="13"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
