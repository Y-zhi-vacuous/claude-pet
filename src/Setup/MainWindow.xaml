<Window x:Class="Setup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="千千安装向导" Width="560" Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：千千 Logo + 步骤指示 -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <Border Width="96" Height="96" Background="#333" CornerRadius="12"
                    HorizontalAlignment="Center">
                <TextBlock Text="🐶" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock x:Name="StepLabel" Text="步骤 1/7" FontSize="11" Foreground="#888"
                       HorizontalAlignment="Center" Margin="0,12,0,0" />
            <TextBlock x:Name="StepTitle" Text="欢迎" FontSize="14" Foreground="White"
                       HorizontalAlignment="Center" FontWeight="Bold" Margin="0,4,0,0" />
        </StackPanel>

        <!-- 右侧：页面内容 -->
        <Grid Grid.Column="1" Margin="30,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 页面内容区 -->
            <StackPanel x:Name="PageContent" Grid.Row="0" VerticalAlignment="Center">
                <!-- 内容由代码动态生成 -->
            </StackPanel>

            <!-- 底部按钮 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="BtnBack" Content="上一步" Width="80" Height="32"
                        Background="#444" Foreground="White" BorderThickness="0"
                        FontSize="13" Click="BtnBack_Click" Visibility="Collapsed" />
                <Button x:Name="BtnNext" Content="下一步" Width="80" Height="32"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        FontSize="13" Margin="10,0,0,0" Click="BtnNext_Click" />
                <Button x:Name="BtnFinish" Content="启动千千" Width="100" Height="32"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        FontSize="13" Margin="10,0,0,0" Click="BtnFinish_Click" Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
